<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".AccountFragment">

    <!-- Custom Toolbar with Back Button -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/accountToolBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Profile"
        app:titleTextColor="@android:color/white"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp">

        <ImageView
            android:id="@+id/profile"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/account" />


        <TextView
            android:id="@+id/fullName"
            android:layout_width="192dp"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="27dp"
            android:layout_marginLeft="200dp"
            android:layout_marginTop="118dp"
            android:layout_marginEnd="24dp"
            android:layout_toEndOf="@+id/profile"
            android:text="Username "
            android:textColor="@color/white"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/fullName"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="27dp"
            android:layout_marginTop="9dp"
            android:layout_marginEnd="25dp"
            android:layout_toEndOf="@+id/profile"
            android:text="Email"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/imageView5"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_below="@+id/profile"
            android:layout_alignParentStart="true"
            android:layout_marginStart="65dp"
            android:layout_marginLeft="80dp"
            android:layout_marginTop="45dp"
            android:layout_marginEnd="42dp"
            android:layout_toStartOf="@+id/editProfile"
            android:src="@drawable/user" />

        <TextView
            android:id="@+id/editProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginLeft="150dp"
            android:layout_marginTop="250dp"
            android:layout_marginEnd="46dp"
            android:drawableEnd="@drawable/arrow_right"
            android:drawablePadding="80dp"
            android:text="Edit Profile"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_below="@+id/imageView5"
            android:layout_alignParentStart="true"
            android:layout_marginStart="65dp"
            android:layout_marginLeft="80dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="42dp"
            android:layout_toStartOf="@+id/security"
            android:src="@drawable/security" />


        <TextView
            android:id="@+id/security"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginLeft="150dp"
            android:layout_marginTop="320dp"
            android:layout_marginEnd="46dp"
            android:drawableEnd="@drawable/arrow_right"
            android:drawablePadding="100dp"
            android:text="Security"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <ImageView
            android:id="@+id/imageView6"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_below="@+id/imageView4"
            android:layout_alignParentStart="true"
            android:layout_marginStart="64dp"
            android:layout_marginLeft="80dp"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="42dp"
            android:layout_toStartOf="@+id/notifications"
            android:src="@drawable/notif" />

        <TextView
            android:id="@+id/notifications"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginLeft="150dp"
            android:layout_marginTop="400dp"
            android:layout_marginEnd="46dp"
            android:drawableEnd="@drawable/arrow_right"
            android:drawablePadding="60dp"
            android:text="Notifications"
            android:textColor="@color/white"
            android:textSize="20sp" />


        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_below="@+id/imageView6"
            android:layout_alignParentStart="true"
            android:layout_marginStart="65dp"
            android:layout_marginLeft="80dp"
            android:layout_marginTop="42dp"
            android:layout_marginEnd="42dp"
            android:layout_toStartOf="@+id/logout"
            android:src="@drawable/signout1" />

        <TextView
            android:id="@+id/logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginLeft="150dp"
            android:layout_marginTop="480dp"
            android:layout_marginEnd="46dp"
            android:drawableEnd="@drawable/arrow_right"
            android:drawablePadding="100dp"
            android:padding="5dp"
            android:text="Logout"
            android:textColor="@color/blue"
            android:textSize="20sp" />


    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
